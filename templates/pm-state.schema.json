{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-pm/pm-state.schema.json",
  "title": "PM State",
  "description": "Schema for .claude/pm-state.json — persistent state file maintained by the PM agent across cycles.",
  "type": "object",
  "required": ["version", "pm_peer_id", "current_cycle", "last_updated", "active_workers", "vo_agents", "completed_tasks", "queued_tasks", "escalations"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Always 1 for this revision."
    },
    "pm_peer_id": {
      "type": "string",
      "description": "The PM agent's claude-peers peer ID."
    },
    "current_cycle": {
      "type": "integer",
      "minimum": 0,
      "description": "The current PM planning cycle number. Incremented each time the PM runs a full plan-dispatch-monitor loop."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last state write."
    },
    "active_workers": {
      "type": "array",
      "description": "Workers currently running or awaiting review.",
      "items": {
        "type": "object",
        "required": ["task_id", "peer_id", "branch", "status", "spawned_at", "last_message_at"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Linear issue ID or internal task ID."
          },
          "peer_id": {
            "type": "string",
            "description": "Worker's claude-peers peer ID."
          },
          "branch": {
            "type": "string",
            "description": "Git branch the worker is using."
          },
          "status": {
            "type": "string",
            "enum": ["spawned", "working", "self_checking", "awaiting_review"],
            "description": "Current worker lifecycle stage."
          },
          "spawned_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the worker was spawned."
          },
          "last_message_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the last message received from this worker."
          }
        },
        "additionalProperties": false
      }
    },
    "vo_agents": {
      "type": "array",
      "description": "Verification Officer agents currently active.",
      "items": {
        "type": "object",
        "required": ["task_id", "vo_peer_id", "worker_peer_id", "branch", "status", "started_at", "review_loop_count"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Task being reviewed."
          },
          "vo_peer_id": {
            "type": "string",
            "description": "VO agent's claude-peers peer ID."
          },
          "worker_peer_id": {
            "type": "string",
            "description": "Peer ID of the worker being reviewed."
          },
          "branch": {
            "type": "string",
            "description": "Branch under review."
          },
          "status": {
            "type": "string",
            "enum": ["reviewing", "pr_created", "ci_monitoring", "comment_loop"],
            "description": "Current VO lifecycle stage."
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the VO started reviewing."
          },
          "pr_url": {
            "type": "string",
            "format": "uri",
            "description": "Pull request URL, if a PR has been created."
          },
          "pr_number": {
            "type": "integer",
            "minimum": 1,
            "description": "Pull request number, if a PR has been created."
          },
          "review_loop_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of review feedback loops completed so far."
          }
        },
        "additionalProperties": false
      }
    },
    "completed_tasks": {
      "type": "array",
      "description": "Tasks that have been approved, merged, and marked done.",
      "items": {
        "type": "object",
        "required": ["task_id", "branch", "pr_url", "merge_sha", "completed_at"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Completed task ID."
          },
          "branch": {
            "type": "string",
            "description": "Branch that was merged."
          },
          "pr_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the merged pull request."
          },
          "merge_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{7,40}$",
            "description": "Git SHA of the merge commit."
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the task was marked done."
          }
        },
        "additionalProperties": false
      }
    },
    "queued_tasks": {
      "type": "array",
      "description": "Tasks pulled from Linear that are waiting to be assigned to workers.",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "priority", "queued_at"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Linear issue ID."
          },
          "title": {
            "type": "string",
            "description": "Task title from Linear."
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4,
            "description": "Priority level (0 = no priority, 1 = urgent, 2 = high, 3 = medium, 4 = low)."
          },
          "queued_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the task was added to the queue."
          }
        },
        "additionalProperties": false
      }
    },
    "escalations": {
      "type": "array",
      "description": "Issues that require human attention or PM intervention.",
      "items": {
        "type": "object",
        "required": ["task_id", "type", "message", "timestamp", "resolved"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Task related to the escalation."
          },
          "type": {
            "type": "string",
            "description": "Escalation category (e.g. 'timeout', 'max_review_loops', 'worker_failed', 'vo_escalation')."
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the escalation."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the escalation was raised."
          },
          "resolved": {
            "type": "boolean",
            "description": "Whether this escalation has been resolved."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
